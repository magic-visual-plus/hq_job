{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-web/main/nicegram.schema.json",
  "productName": "HQ Job Manager",
  "version": "0.1.0",
  "identifier": "com.hqjob.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:9090/ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "HQ Job Manager",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/hq_job_server"
    ]
  }
}
